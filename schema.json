{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "guard-technologies enrichment schema",
  "description": "Consolidated source of truth for guard.ch technology detection. Each technology record combines the webappanalyzer/Wappalyzer fingerprint and basic fields (cats, website, icon, js, dom, scriptSrc, etc.) with the guard.ch enrichment layer (trust/privacy/abuse scores, vendor and compliance facts, summaries). Records are keyed by the technology name (technologies/*.json) or category id (categories.json); groups.json holds category groups. This repository previously held only the enrichment layer and joined to BrowserProject/webdetector; it now contains both.",
  "$defs": {
    "score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 10
    },
    "url_list": {
      "type": "array",
      "items": {
        "type": "string",
        "format": "uri"
      }
    },
    "non-empty-non-blank-string": {
      "type": "string",
      "pattern": "^(?!\\s*$).+"
    },
    "technology": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "abuse_score": {
          "$ref": "#/$defs/score"
        },
        "ai_generated_likelihood": {
          "$ref": "#/$defs/score"
        },
        "cats": {
          "type": "array",
          "items": {
            "type": "number"
          },
          "minItems": 1
        },
        "certIssuer": {
          "$ref": "#/$defs/non-empty-non-blank-string"
        },
        "company_size_bucket": {
          "type": "string",
          "enum": [
            "solo",
            "startup",
            "smb",
            "midmarket",
            "enterprise",
            "mega"
          ]
        },
        "confidence": {
          "$ref": "#/$defs/score"
        },
        "cookies": {
          "type": "object",
          "additionalProperties": false,
          "patternProperties": {
            "^.+$": {},
            "additionalProperties": {
              "type": "string"
            }
          }
        },
        "cpe": {
          "type": "string",
          "pattern": "^[Cc][Pp][Ee]:(/|\\d+\\.\\d+)[^:]*(:?[^:]*){0,11}$"
        },
        "css": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non-empty-non-blank-string"
          }
        },
        "dark_pattern_likelihood": {
          "$ref": "#/$defs/score"
        },
        "description": {
          "type": "string",
          "pattern": "^.{0,550}$"
        },
        "dns": {
          "type": "object",
          "additionalProperties": false,
          "patternProperties": {
            "^.+$": {}
          }
        },
        "dom": {
          "oneOf": [
            {
              "type": "array",
              "items": {
                "$ref": "#/$defs/non-empty-non-blank-string"
              }
            },
            {
              "$ref": "#/$defs/non-empty-non-blank-string"
            },
            {
              "type": "object",
              "additionalProperties": false,
              "patternProperties": {
                "^.+$": {}
              }
            }
          ]
        },
        "enterprise_adoption": {
          "type": "string",
          "enum": [
            "common",
            "limited",
            "none",
            "widespread"
          ]
        },
        "enterprise_pricing_only": {
          "type": "boolean"
        },
        "excludes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non-empty-non-blank-string"
          }
        },
        "founded_year": {
          "type": "integer",
          "minimum": 1900,
          "maximum": 2100
        },
        "gdpr_compliant": {
          "type": "boolean"
        },
        "has_bug_bounty": {
          "type": "boolean"
        },
        "has_free_tier": {
          "type": "boolean"
        },
        "has_responsible_disclosure_policy": {
          "type": "boolean"
        },
        "has_self_hosted_option": {
          "type": "boolean"
        },
        "headers": {
          "type": "object",
          "additionalProperties": false,
          "patternProperties": {
            "^.+$": {},
            "additionalProperties": {
              "type": "string"
            }
          }
        },
        "headquarters_country": {
          "type": "string",
          "pattern": "^[A-Z]{2}$"
        },
        "hipaa_compliant": {
          "type": "boolean"
        },
        "history": {
          "type": "string",
          "maxLength": 2000
        },
        "html": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non-empty-non-blank-string"
          }
        },
        "icon": {
          "$ref": "#/$defs/non-empty-non-blank-string"
        },
        "implies": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non-empty-non-blank-string"
          }
        },
        "iso27001": {
          "type": "boolean"
        },
        "js": {
          "type": "object",
          "additionalProperties": false,
          "patternProperties": {
            "^.+$": {},
            "additionalProperties": {
              "type": "string"
            }
          }
        },
        "kind": {
          "type": "string",
          "enum": [
            "commercial-product",
            "commercial-saas",
            "infrastructure",
            "language",
            "oss-library",
            "oss-project",
            "protocol",
            "standard"
          ]
        },
        "license_type": {
          "type": "string"
        },
        "maintenance_status": {
          "type": "string",
          "enum": [
            "abandoned",
            "active",
            "deprecated",
            "dormant",
            "maintained"
          ]
        },
        "meta": {
          "type": "object",
          "additionalProperties": false,
          "patternProperties": {
            "^.+$": {},
            "additionalProperties": {
              "type": "string"
            }
          }
        },
        "oss": {
          "type": "boolean"
        },
        "overall_trust_score": {
          "$ref": "#/$defs/score"
        },
        "ownership_type": {
          "type": "string",
          "enum": [
            "foundation",
            "independent",
            "public",
            "subsidiary",
            "vc-backed"
          ]
        },
        "parent_company": {
          "type": "string"
        },
        "pci_dss": {
          "type": "boolean"
        },
        "popularity_tier": {
          "type": "string",
          "enum": [
            "dominant",
            "growing",
            "mainstream",
            "niche"
          ]
        },
        "pricing": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^(low|mid|high|freemium|poa|payg|onetime|recurring)$"
          }
        },
        "pricing_model": {
          "type": "string",
          "enum": [
            "dual-license",
            "enterprise-only",
            "free",
            "freemium",
            "one-time",
            "subscription",
            "usage-based"
          ]
        },
        "pricing_transparency_score": {
          "$ref": "#/$defs/score"
        },
        "privacy_score": {
          "$ref": "#/$defs/score"
        },
        "probe": {
          "type": "object",
          "additionalProperties": false,
          "patternProperties": {
            "^.+$": {},
            "additionalProperties": {
              "type": "string"
            }
          }
        },
        "requires": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non-empty-non-blank-string"
          }
        },
        "requiresCategory": {
          "type": "array",
          "items": {
            "type": "number"
          }
        },
        "robots": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non-empty-non-blank-string"
          }
        },
        "saas": {
          "type": "boolean"
        },
        "scriptSrc": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non-empty-non-blank-string"
          }
        },
        "scripts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non-empty-non-blank-string"
          }
        },
        "soc2_type2": {
          "type": "boolean"
        },
        "source_urls": {
          "$ref": "#/$defs/url_list"
        },
        "starting_price_usd_monthly": {
          "type": "number",
          "minimum": 0
        },
        "summary_abuse": {
          "type": "string",
          "maxLength": 2000
        },
        "technical_depth_score": {
          "$ref": "#/$defs/score"
        },
        "text": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non-empty-non-blank-string"
          }
        },
        "tracker_density": {
          "type": "string",
          "enum": [
            "heavy",
            "light",
            "moderate",
            "none"
          ]
        },
        "url": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non-empty-non-blank-string"
          }
        },
        "vendor_stability_score": {
          "$ref": "#/$defs/score"
        },
        "website": {
          "$ref": "#/$defs/non-empty-non-blank-string"
        },
        "white_label_wrapper_likelihood": {
          "$ref": "#/$defs/score"
        },
        "xhr": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non-empty-non-blank-string"
          }
        }
      },
      "required": [
        "cats",
        "website"
      ]
    },
    "category": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "business_function": {
          "type": "string",
          "enum": [
            "analytics",
            "commerce",
            "communication",
            "content",
            "developer-tool",
            "identity",
            "infrastructure",
            "media",
            "payment",
            "productivity",
            "security"
          ]
        },
        "confidence": {
          "$ref": "#/$defs/score"
        },
        "description": {
          "type": "string"
        },
        "groups": {
          "type": "array",
          "items": {
            "type": "integer"
          }
        },
        "inherent_attack_surface_score": {
          "$ref": "#/$defs/score"
        },
        "inherent_pii_exposure_score": {
          "$ref": "#/$defs/score"
        },
        "inherent_privacy_risk_score": {
          "$ref": "#/$defs/score"
        },
        "inherent_third_party_data_sharing_score": {
          "$ref": "#/$defs/score"
        },
        "name": {
          "type": "string"
        },
        "placement": {
          "type": "string",
          "enum": [
            "client",
            "infrastructure",
            "mixed",
            "server"
          ]
        },
        "priority": {
          "type": "integer"
        },
        "recommended_scrutiny_level": {
          "type": "string",
          "enum": [
            "critical",
            "high",
            "low",
            "moderate"
          ]
        },
        "regulatory_relevance": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "ccpa",
              "cookie-law",
              "coppa",
              "ferpa",
              "gdpr",
              "glba",
              "hipaa",
              "pci-dss",
              "pii-handling",
              "soc2"
            ]
          }
        },
        "source_urls": {
          "$ref": "#/$defs/url_list"
        },
        "tracker_likelihood_score": {
          "$ref": "#/$defs/score"
        }
      }
    },
    "group": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "$ref": "#/$defs/non-empty-non-blank-string"
        }
      },
      "required": [
        "name"
      ]
    }
  }
}
